
# Triage Copilot — Environment Configuration
# Copy this file to .env and fill in real values.
# ============================================

# ---------- Provider Credentials ----------
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here
GOOGLE_AI_STUDIO_API_KEY=your_google_ai_studio_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ---------- Provider Base URLs (OpenAI-compatible endpoints) ----------
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
GOOGLE_AI_STUDIO_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---------- LLM Client Behavior ----------
LLM_REQUEST_TIMEOUT_SECONDS=15
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=1

# ---------- App Config ----------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# ---------- Database ----------
DATABASE_URL=sqlite:///./data/triage.db

# ---------- Conversation Controller Limits ----------
MAX_QUESTIONS_PER_CONVERSATION=8
CONVERSATION_TIMEOUT_SECONDS=600

# ---------- API Auth (demo-level only) ----------
API_KEY=changeme_local_dev_key

# ---------- Misc ----------
SYNTHETIC_DATA_ONLY=true